# LLM providers (use one or both depending on active model)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Runtime
INSTALL_MODE=local
PORT=7000
RUNTIME_MODE=local
# Leave blank unless you intentionally want to override the default local app-data folders.
# Windows defaults:
#   DATA_ROOT=%LOCALAPPDATA%\DaedalMap\data
#   PACKS_ROOT=%LOCALAPPDATA%\DaedalMap\packs
#   CONFIG_DIR=%LOCALAPPDATA%\DaedalMap\config
#   STATE_DIR=%LOCALAPPDATA%\DaedalMap\state
#   CACHE_DIR=%LOCALAPPDATA%\DaedalMap\cache
#   LOG_DIR=%LOCALAPPDATA%\DaedalMap\logs
DATA_ROOT=
PACKS_ROOT=
CONFIG_DIR=
STATE_DIR=
CACHE_DIR=
LOG_DIR=
RUNTIME_CONFIG_PATH=

# Optional URL overrides.
# Leave blank for normal local use.
# APP_URL is the full public URL the app should advertise for itself.
# SITE_URL is the docs/account/site host paired with the app runtime.
APP_URL=
SITE_URL=

# Cloud-backed runtime data (required when RUNTIME_MODE=cloud)
S3_BUCKET=
S3_PREFIX=published
# Optional override for the local cloud metadata/cache working area.
# Leave blank unless you want it somewhere other than the default temp/app-data cache.
CLOUD_CACHE_ROOT=
# Optional explicit lane names for tools that compare both namespaces.
S3_STAGING_PREFIX=staging
S3_PUBLISHED_PREFIX=published
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Supabase control plane / auth
# SUPABASE_URL: project URL from Supabase > Project Settings > API
# SUPABASE_ANON_KEY: safe to expose to browser, used by frontend auth client
# SUPABASE_SERVICE_KEY: secret, server-side only, bypasses RLS for profile/plan reads
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
