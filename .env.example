# LLM providers (use one or both depending on active model)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Runtime
PORT=8000
COUNTY_MAP_ROOT=
GLOBAL_MAP_ROOT=
DATA_ROOT=

# Storage mode
# local = use DATA_ROOT or local sibling county-map-data
# s3 = sync bucket contents into S3_LOCAL_CACHE and use that as DATA_ROOT
STORAGE_MODE=local

# S3-backed runtime data (required when STORAGE_MODE=s3)
S3_BUCKET=
S3_PREFIX=
S3_LOCAL_CACHE=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Supabase control plane / auth
# SUPABASE_URL: project URL from Supabase > Project Settings > API
# SUPABASE_ANON_KEY: safe to expose to browser, used by frontend auth client
# SUPABASE_SERVICE_KEY: secret, server-side only, bypasses RLS for profile/plan reads
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
