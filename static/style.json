{
  "version": 8,
  "name": "Basic",
  "sources": {
    "counties": {
      "type": "vector",
      "url": "mbtiles://{counties}"
    }
  },
  "glyphs": "fonts/{fontstack}/{range}.pbf",
  "sprite": "",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#040b14"
      }
    },
    {
      "id": "county-fill",
      "type": "fill",
      "source": "counties",
      "source-layer": "counties", 
      "paint": {
        "fill-color": "#10293a",
        "fill-opacity": 0.82
      }
    },
    {
      "id": "county-outline",
      "type": "line",
      "source": "counties",
      "source-layer": "counties",
      "paint": {
        "line-color": "#78d9ff",
        "line-opacity": 0.28,
        "line-width": 0.7
      }
    }
  ]
}
